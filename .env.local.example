# Admin con login + guardado automatico sobre JSON.
# No configurar Neon, Firebase ni Vercel Blob.

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
ADMIN_EMAILS=admin@example.com

# GitHub Contents API para guardar data/*.json desde /admin.
ADMIN_GITHUB_OWNER=AminVentura
ADMIN_GITHUB_REPO=Auto-Lava-Garcia
ADMIN_GITHUB_BRANCH=main
ADMIN_GITHUB_TOKEN=

# Opcional: redeploy manual desde el dashboard despues de guardar.
ADMIN_VERCEL_DEPLOY_HOOK_URL=
